# Django Secret Key
SECRET_KEY=django-insecure-dummy-key-for-local-development

# Debug Mode (True for local development, False for production)
DEBUG=True

# Allowed Hosts (comma-separated list, e.g., localhost,127.0.0.1)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL
# SQLite syntax: sqlite:///db.sqlite3 (relative path) or sqlite:////absolute/path/to/db.sqlite3
# PostgreSQL syntax: postgres://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Email configuration for local development (Gmail SMTP)
EMAIL_HOST_USER_DEV=your-email@gmail.com
EMAIL_HOST_PASSWORD_DEV=your-16-digit-google-app-password

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0


